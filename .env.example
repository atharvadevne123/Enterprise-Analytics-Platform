# ============================================================
# Enterprise Analytics Platform — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/analytics_warehouse
# For local development / testing:
# DATABASE_URL=sqlite:///./test.db

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=unified-analytics

# --- Service Ports ---
ANALYTICS_API_PORT=8000
ANOMALY_DETECTION_PORT=8001
FORECASTING_SERVICE_PORT=8002

# --- Forecasting ---
DEFAULT_FORECAST_HORIZON=30
MAX_FORECAST_HORIZON=365

# --- Anomaly Detection ---
ZSCORE_THRESHOLD=2.0
IQR_MULTIPLIER=1.5

# --- Logging ---
LOG_LEVEL=INFO

# --- Workers ---
API_WORKERS=4

# --- Docker (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=analytics_warehouse

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql://postgres:password@localhost:5432/airflow
AIRFLOW__CORE__FERNET_KEY=change_me_in_production
