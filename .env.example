# ============================================================================
# Enterprise Analytics Platform — Environment Variables
# Copy this file to .env and fill in the values before running.
# ============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL / Analytics Warehouse
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/analytics_warehouse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=analytics_warehouse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Kafka / Streaming
# ---------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_ORDERS=orders
KAFKA_TOPIC_DELIVERIES=deliveries
KAFKA_TOPIC_FINANCIAL=financial-transactions
KAFKA_TOPIC_INVENTORY=inventory-updates
KAFKA_CONSUMER_GROUP=unified-analytics

# ---------------------------------------------------------------------------
# Zookeeper
# ---------------------------------------------------------------------------
ZOOKEEPER_CONNECT=localhost:2181

# ---------------------------------------------------------------------------
# Apache Spark
# ---------------------------------------------------------------------------
SPARK_MASTER_URL=spark://localhost:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=4g
SPARK_EXECUTOR_CORES=2

# ---------------------------------------------------------------------------
# Apache Airflow
# ---------------------------------------------------------------------------
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql://postgres:password@localhost:5432/airflow
AIRFLOW__CORE__FERNET_KEY=changeme_generate_with_python_-c_from_cryptography.fernet_import_Fernet_print_Fernet.generate_key()
AIRFLOW__WEBSERVER__SECRET_KEY=changeme

# ---------------------------------------------------------------------------
# API Services
# ---------------------------------------------------------------------------
ANALYTICS_API_PORT=8000
ANOMALY_DETECTION_PORT=8001
FORECASTING_SERVICE_PORT=8002
API_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Prometheus / Monitoring
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Great Expectations
# ---------------------------------------------------------------------------
GE_DATA_CONTEXT_ROOT_DIR=./great_expectations

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=changeme_replace_with_random_32_char_string
